# Database (Supabase / Neon / Railway — must be hosted Postgres)
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# Redis (Upstash recommended) — optional but recommended for distributed locking
REDIS_URL="redis://default:password@host:6379"

# Secret for the cron endpoint (optional but recommended in production)
CRON_SECRET="your-random-secret-here"
